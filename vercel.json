{
  "crons": [
    {
      "path": "/api/refresh-data",
      "schedule": "0 6 * * 1-5"
    }
  ],
  "functions": {
    "api/refresh-data.js": {
      "maxDuration": 300
    }
  },
  "headers": [
    {
      "source": "/data/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, stale-while-revalidate=86400"
        }
      ]
    }
  ]
}
